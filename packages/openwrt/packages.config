
# The SDK ships with buildbot-oriented defaults like CONFIG_ALL=y and
# CONFIG_ALL_KMODS=y. Explicitly turn them off so package builds only select
# our requested dependencies instead of unrelated kernel modules.

# CONFIG_ALL is not set
# CONFIG_ALL_KMODS is not set
# CONFIG_ALL_NONSHARED is not set

CONFIG_LIBCURL_MBEDTLS=y

CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libmbedtls=y
CONFIG_PACKAGE_libnl-core=y
CONFIG_PACKAGE_libnl-route=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libunwind=y
CONFIG_PACKAGE_zlib=y
CONFIG_PACKAGE_libzstd=y

CONFIG_PACKAGE_keen-pbr=m
CONFIG_PACKAGE_keen-pbr-headless=m
