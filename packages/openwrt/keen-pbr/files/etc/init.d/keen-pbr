#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

if type extra_command >/dev/null 2>&1; then
    extra_command "reapply_firewall" "Send SIGUSR1 to the running service"
    extra_command "reapply_dnsmasq_config" "Regenerate keen-pbr dnsmasq config and reload dnsmasq"
else
    EXTRA_COMMANDS="reapply_firewall reapply_dnsmasq_config"
    EXTRA_HELP="        reapply_firewall        Send SIGUSR1 to the running service
        reapply_dnsmasq_config  Regenerate keen-pbr dnsmasq config and reload dnsmasq"
fi

PROG=/usr/sbin/keen-pbr
CONFIG=/etc/keen-pbr/config.json
HELPER=/usr/lib/keen-pbr/dnsmasq.sh
PIDFILE=/var/run/keen-pbr.pid

start_service() {
    [ -x "$PROG" ] || return 1
    [ -f "$CONFIG" ] || return 1

    mkdir -p /var/cache/keen-pbr

    if [ -x "$HELPER" ]; then
        "$HELPER" configure || return 1
        "$HELPER" reload || true
    fi

    procd_open_instance
    procd_set_param command "$PROG" --config "$CONFIG" service
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    if [ -x "$HELPER" ]; then
        "$HELPER" restore || true
        "$HELPER" reload || true
    fi
}

reload_service() {
    [ -s "$PIDFILE" ] || return 1

    reapply_dnsmasq_config || return 1

    kill -HUP "$(cat "$PIDFILE")"
}

reapply_firewall() {
    [ -s "$PIDFILE" ] || return 1
    kill -SIGUSR1 "$(cat "$PIDFILE")"
}

reapply_dnsmasq_config() {
    if [ -x "$HELPER" ]; then
        "$HELPER" configure || return 1
        "$HELPER" reload || true
    fi
}
