#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

if type extra_command >/dev/null 2>&1; then
    extra_command "reapply_firewall" " Send SIGUSR1 to the running service"
    extra_command "reapply_dnsmasq_config" " Regenerate keen-pbr dnsmasq config and restart dnsmasq"
else
    EXTRA_COMMANDS="reapply_firewall reapply_dnsmasq_config"
    EXTRA_HELP="        reapply_firewall        Send SIGUSR1 to the running service
        reapply_dnsmasq_config  Regenerate keen-pbr dnsmasq config and restart dnsmasq"
fi

PROG=/usr/sbin/keen-pbr
CONFIG=/etc/keen-pbr/config.json
HELPER=/usr/lib/keen-pbr/dnsmasq.sh
PIDFILE=/var/run/keen-pbr.pid

script_name() {
    basename "${initscript:-$0}"
}

rc_root() {
    printf '%s' "${IPKG_INSTROOT:-}"
}

start_link_path() {
    printf '%s/etc/rc.d/S%02d%s' "$(rc_root)" "$START" "$(script_name)"
}

stop_link_path() {
    printf '%s/etc/rc.d/K%02d%s' "$(rc_root)" "$STOP" "$(script_name)"
}

is_enabled() {
    [ -L "$(start_link_path)" ] || [ -L "$(stop_link_path)" ]
}

enable() {
    local root name

    root="$(rc_root)"
    name="$(script_name)"

    mkdir -p "$root/etc/rc.d"
    ln -sf "../init.d/${name}" "$(start_link_path)"
    ln -sf "../init.d/${name}" "$(stop_link_path)"

    [ -n "$IPKG_INSTROOT" ] && return 0

    if [ -x "$HELPER" ]; then
        "$HELPER" install-persistent || return 1
    fi
}

disable() {
    rm -f "$(start_link_path)" "$(stop_link_path)"

    [ -n "$IPKG_INSTROOT" ] && return 0

    if [ -x "$HELPER" ]; then
        "$HELPER" uninstall-persistent || return 1
    fi
}

start_service() {
    [ -x "$PROG" ] || return 1
    [ -f "$CONFIG" ] || return 1

    mkdir -p /var/cache/keen-pbr

    if [ -x "$HELPER" ]; then
        "$HELPER" ensure-runtime-prereqs || return 1
        "$HELPER" activate || return 1
    fi

    procd_open_instance
    procd_set_param command "$PROG" --config "$CONFIG" service
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance
}

stop_service() {
    [ -n "$KEEN_PBR_SKIP_DNSMASQ" ] && return 0
    is_enabled || return 0

    if [ -x "$HELPER" ]; then
        "$HELPER" deactivate || true
    fi
}

reload_service() {
    [ -s "$PIDFILE" ] || return 1

    reapply_dnsmasq_config || return 1

    kill -HUP "$(cat "$PIDFILE")"
}

reapply_firewall() {
    [ -s "$PIDFILE" ] || return 1
    kill -SIGUSR1 "$(cat "$PIDFILE")"
}

reapply_dnsmasq_config() {
    if [ -x "$HELPER" ]; then
        "$HELPER" ensure-runtime-prereqs || return 1
        "$HELPER" activate || return 1
    fi
}
