#!/bin/sh

[ "$PKG_UPGRADE" = "1" ] && exit 0

cat <<'EOF'
keen-pbr has restored the dnsmasq configuration.
If internet access stopped working after package removal, restore upstream DNS manually with UCI.
Example:
  uci add_list dhcp.@dnsmasq[0].server='8.8.8.8'
  uci commit dhcp
  /etc/init.d/dnsmasq restart
EOF

exit 0
