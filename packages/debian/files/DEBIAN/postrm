#!/bin/sh

set -e

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

cat <<'EOF'
keen-pbr has been removed.
dnsmasq fallback config from keen-pbr is no longer available.
If upstream DNS servers are not configured in your dnsmasq settings,
internet access may stop working.
Configure upstream DNS servers manually if they are not set yet.

Hint: add "server=8.8.8.8" (or other DNS servers) to the /etc/dnsmasq.conf file.
EOF

exit 0
