#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

ifneq ($(shell command -v ccache),)
CCACHE_LAUNCHER = -DCMAKE_CXX_COMPILER_LAUNCHER:STRING=ccache
endif

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_INSTALL_BINDIR:PATH=sbin \
		-DKEEN_PBR_DEFAULT_CONFIG_PATH:STRING=/etc/keen-pbr/config.json \
		-DKEEN_PBR_RESOLVER_FALLBACK_CONFIG:STRING=/etc/keen-pbr/dnsmasq-fallback.conf \
		-DKEEN_PBR_SYSTEM_RESOLVER_HOOK:STRING=/usr/lib/keen-pbr/dnsmasq.sh \
		-DKEEN_PBR_TARGET_OS:STRING=debian \
		-DKEEN_PBR_TARGET_VERSION:STRING=$$(. /etc/os-release && printf '%s' "$$VERSION_ID") \
		-DKEEN_PBR_TARGET_ARCH:STRING=$$(dpkg-architecture -qDEB_HOST_ARCH) \
		-DKEEN_PBR_BUILD_VARIANT:STRING=headless \
		-DWITH_API=OFF $(CCACHE_LAUNCHER)

override_dh_auto_test:

override_dh_dwz:
	# Bullseye dwz cannot process DW_OP_255 emitted in the current debug data.
	# dwz only optimizes debug information; package stripping still runs normally.
	:

override_dh_auto_install:
	dh_auto_install
	install -d debian/keen-pbr-headless/var/cache/keen-pbr
