{
  "daemon": {
    "pid_file": "/tmp/keen-pbr.pid",
    "cache_dir": "/opt/var/cache/keen-pbr",
    "strict_enforcement": false
  },

  "outbounds": [
    {
      "type": "table",
      "tag": "wan",
      "table": 254
    },
    {
      "type": "blackhole",
      "tag": "block"
    }
  ],

  "lists": {
    "local_list": {
      "domains": [
        "example.com"
      ],
      "ip_cidrs": []
    }
  },

  "dns": {
    "system_resolver": {
      "address": "127.0.0.1"
    },
    "dns_test_server": {
      "listen": "127.0.0.88:12153"
    },
    "servers": [
      {
        "tag": "keenetic_dns",
        "type": "keenetic"
      },
      {
        "tag": "quad9",
        "address": "9.9.9.9"
      }
    ],
    "rules": [],
    "fallback": ["keenetic_dns"]
  },

  "fwmark": {
    "start": "0x00010000",
    "mask": "0x00FF0000"
  },

  "iproute": {
    "table_start": 150
  },

  "route": {
    "inbound_interfaces": ["br0"],
    "rules": [
      {
        "enabled": true,
        "list": [
          "local_list"
        ],
        "outbound": "block"
      }
    ]
  }
}
