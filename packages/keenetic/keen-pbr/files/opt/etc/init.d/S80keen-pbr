#!/bin/sh

. /opt/etc/keen-pbr/defaults

ENABLED=yes
PROCS=$(basename "$KEEN_PBR")
PIDFILE="/opt/var/run/keen-pbr.pid"
ARGS="--config $CONFIG --pid-file $PIDFILE ${KEEN_PBR_ARGS:-} service"
PREARGS=""
POSTCMD=""
DESC="keen-pbr"
PATH=/opt/sbin:/opt/bin:/opt/usr/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
IPSET_PROBE_SET="kpbr_probe_hash_net"
IPSET_COMPONENTS_MESSAGE="ipset kernel modules are not available. Make sure that you followed the installation process and installed all required components: Netfilter Subsystem Kernel Modules and Xtables-addons Extension Package for Netfilter."

log() {
    logger -s -t "keen-pbr" "$1"
}

log_error() {
    logger -s -t "keen-pbr" -p "user.err" "$1"
}

is_module_loaded() {
    local module="$1"

    lsmod | grep -q "^${module}[[:space:]]"
}

module_path_for() {
    local module="$1"

    printf '/lib/modules/%s/%s.ko\n' "$(uname -r)" "$module"
}

ensure_kernel_module_loaded() {
    local module="$1"
    local module_path="$2"
    local missing_message="$3"
    local failure_message="$4"

    if is_module_loaded "$module"; then
        return 0
    fi

    if [ ! -f "$module_path" ]; then
        log_error "$missing_message"
        return 0
    fi

    if ! insmod "$module_path" 2>/dev/null; then
        log_error "$failure_message"
        return 0
    fi

    return 0
}

try_kernel_module_loaded() {
    local module="$1"
    local module_path

    if is_module_loaded "$module"; then
        return 0
    fi

    module_path="$(module_path_for "$module")"
    if [ ! -f "$module_path" ]; then
        return 1
    fi

    insmod "$module_path" 2>/dev/null
}

ipset_hash_net_available() {
    command -v ipset >/dev/null 2>&1 || return 1

    if ipset create "$IPSET_PROBE_SET" hash:net family inet -exist >/dev/null 2>&1; then
        ipset destroy "$IPSET_PROBE_SET" >/dev/null 2>&1 || true
        return 0
    fi

    ipset destroy "$IPSET_PROBE_SET" >/dev/null 2>&1 || true
    return 1
}

check_netfilter_addons_component() {
    local components

    if ! components="$(wget -O - localhost:79/rci/show/version/ndw/components 2>/dev/null)"; then
        log_error "Failed to fetch installed Keenetic components"
        return 0
    fi

    case ",$components," in
        *,opkg-kmod-netfilter-addons,*)
            return 0
            ;;
        *)
            log_error "Missing Keenetic component opkg-kmod-netfilter-addons"
            return 0
            ;;
    esac
}

ensure_ipset_modules_loaded() {
    if ipset_hash_net_available; then
        try_kernel_module_loaded xt_set >/dev/null 2>&1 || true
        return 0
    fi

    try_kernel_module_loaded nfnetlink >/dev/null 2>&1 || true
    try_kernel_module_loaded ip_set >/dev/null 2>&1 || true
    try_kernel_module_loaded ip_set_hash_net >/dev/null 2>&1 || true
    try_kernel_module_loaded xt_set >/dev/null 2>&1 || true

    if ipset_hash_net_available; then
        return 0
    fi

    log_error "$IPSET_COMPONENTS_MESSAGE Required probe failed: ipset create $IPSET_PROBE_SET hash:net family inet -exist"
}

ensure_xt_multiport_loaded() {
    local module_path

    module_path="$(module_path_for xt_multiport)"

    ensure_kernel_module_loaded \
        xt_multiport \
        "$module_path" \
        "xt_multiport module not loaded and not found at $module_path. You can safely ignore this message if you are running a NDMS version lower than 3.x" \
        "Failed to load xt_multiport from $module_path"
}

check_runtime_dependencies() {
    check_netfilter_addons_component
    ensure_ipset_modules_loaded
    ensure_xt_multiport_loaded
}

has_daemon_arg() {
    for arg in $ARGS; do
        [ "$arg" = "$1" ] && return 0
    done
    return 1
}

ensure_raw_table_available() {
    local raw_module

    grep -qx raw /proc/net/ip_tables_names 2>/dev/null && return 0
    raw_module="/lib/modules/$(uname -r)/iptable_raw.ko"
    if [ ! -f "$raw_module" ]; then
        log_error "--use-raw-prerouting was requested, but $raw_module is unavailable"
        return 1
    fi
    if ! insmod "$raw_module" 2>/dev/null && ! grep -qx raw /proc/net/ip_tables_names 2>/dev/null; then
        log_error "--use-raw-prerouting was requested, but failed to load $raw_module"
        return 1
    fi
    if ! grep -qx raw /proc/net/ip_tables_names 2>/dev/null || ! iptables -t raw -S >/dev/null 2>&1; then
        log_error "--use-raw-prerouting was requested, but raw table probe failed after loading $raw_module"
        return 1
    fi
}

enable_hwnat() {
    log "Enabling HW NAT..."
    sysctl -w net.ipv4.netfilter.ip_conntrack_fastnat=1 2>/dev/null || true
    sysctl -w net.netfilter.nf_conntrack_fastnat=1 2>/dev/null || true
}

disable_hwnat() {
    log "Disabling HW NAT..."
    sysctl -w net.ipv4.netfilter.ip_conntrack_fastnat=0 2>/dev/null || true
    sysctl -w net.netfilter.nf_conntrack_fastnat=0 2>/dev/null || true
}

signal_service() {
    local signal="$1"
    local pid

    if [ ! -s "$PIDFILE" ]; then
        log_error "Cannot send $signal to keen-pbr: PID file $PIDFILE is missing or empty"
        return 1
    fi

    read -r pid < "$PIDFILE"
    if [ -z "$pid" ]; then
        log_error "Cannot send $signal to keen-pbr: PID file $PIDFILE does not contain a PID"
        return 1
    fi

    if ! kill "-$signal" "$pid"; then
        log_error "Failed to send $signal to keen-pbr PID $pid from $PIDFILE"
        return 1
    fi

    log "Sent $signal to keen-pbr PID $pid"

    return 0
}

pidof() {
    local pid
    [ "$1" = "$PROCS" ] || { command pidof "$@"; return $?; }
    [ -s "$PIDFILE" ] || return 1
    pid=$(cat "$PIDFILE") || return 1
    [ -d "/proc/$pid" ] || return 1
    printf '%s\n' "$pid"
}

prepare_start() {
    check_runtime_dependencies
    if has_daemon_arg --use-raw-prerouting; then
        ensure_raw_table_available || return 1
    fi
    disable_hwnat
}

prepare_stop() {
    enable_hwnat
}

reapply_dnsmasq_config() {
    if [ -x "$DNSMASQ_HELPER" ]; then
        "$DNSMASQ_HELPER" reload || return 1
    fi
}

case "$1" in
    reload)
        signal_service HUP
        exit $?
        ;;
    reapply-firewall)
        signal_service SIGUSR1
        exit $?
        ;;
    reapply-dnsmasq-config)
        reapply_dnsmasq_config
        exit $?
        ;;
    start|restart|restartall)
        prepare_start
        ;;
    stop|kill)
        prepare_stop
        ;;
esac

. /opt/etc/init.d/rc.func
