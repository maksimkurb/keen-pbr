FROM ubuntu:24.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
      bash \
      build-essential \
      ca-certificates \
      clang \
      curl \
      flex \
      bison \
      g++ \
      gawk \
      gcc-multilib \
      g++-multilib \
      gettext \
      git \
      libncurses5-dev \
      libssl-dev \
      python3 \
      python3-cryptography \
      python3-setuptools \
      python3-pyelftools \
      rsync \
      swig \
      unzip \
      file \
      wget \
      xz-utils \
      zlib1g-dev \
      zstd && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/bun /tmp/keen-pbr-home && \
    chown -R 1000:1000 /opt/bun /tmp/keen-pbr-home

ENV BUN_INSTALL=/opt/bun
ENV HOME=/tmp/keen-pbr-home
ENV PATH=${BUN_INSTALL}/bin:${PATH}

USER 1000:1000
WORKDIR /tmp/keen-pbr-home

RUN curl -fsSL https://bun.sh/install | bash
